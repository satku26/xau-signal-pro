body{
    margin:0;
    padding:20px;
    background:#0f172a;
    color:white;
    font-family:Arial, Helvetica, sans-serif;
}

.container{
    max-width:500px;
    margin:auto;
}

h1{
    text-align:center;
}

.card{
    background:#1e293b;
    border-radius:12px;
    padding:15px;
    margin-top:15px;
}

.card h2{
    margin:0 0 10px;
    color:#38bdf8;
}

.card p{
    font-size:24px;
    font-weight:bold;
}